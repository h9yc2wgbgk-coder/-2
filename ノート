        let canvas, ctx, sizeSlider, isDrawing = false, currentColor = '#ff007f', penMode = 'neon', hasDrawnSomething = false;
        function initCanvas() {
            canvas = document.getElementById('paintCanvas'); if (!canvas) return; ctx = canvas.getContext('2d'); sizeSlider = document.getElementById('penSize');
            const rect = canvas.getBoundingClientRect(); canvas.width = rect.width; canvas.height = rect.width; ctx.lineCap = 'round'; ctx.lineJoin = 'round'; hasDrawnSomething = false;
            canvas.removeEventListener('mousedown', startDrawing); canvas.removeEventListener('mousemove', draw);
            canvas.addEventListener('mousedown', startDrawing); canvas.addEventListener('mousemove', draw); canvas.addEventListener('mouseup', () => isDrawing = false);
            canvas.addEventListener('touchstart', startDrawing, { passive: false }); canvas.addEventListener('touchmove', draw, { passive: false }); canvas.addEventListener('touchend', () => isDrawing = false);
        }
        function getPos(e) { const rect = canvas.getBoundingClientRect(); let cx = e.touches ? e.touches[0].clientX : e.clientX; let cy = e.touches ? e.touches[0].clientY : e.clientY; return { x: cx - rect.left, y: cy - rect.top }; }
        function startDrawing(e) { isDrawing = true; hasDrawnSomething = true; const pos = getPos(e); ctx.beginPath(); ctx.moveTo(pos.x, pos.y); ctx.lineWidth = sizeSlider.value; ctx.strokeStyle = currentColor; ctx.lineTo(pos.x, pos.y); ctx.stroke(); }
        function draw(e) {
            if (!isDrawing) return; if (e.cancelable) e.preventDefault(); const pos = getPos(e); ctx.lineWidth = sizeSlider.value;
            if (penMode === 'neon') { ctx.strokeStyle = currentColor; ctx.shadowColor = currentColor; ctx.shadowBlur = 8; }
            else if (penMode === 'glitter') { ctx.strokeStyle = currentColor; ctx.shadowColor = '#fff'; ctx.shadowBlur = 4; if (Math.random() > 0.4) { ctx.fillStyle = Math.random() > 0.5 ? '#fff' : '#ffff00'; ctx.fillRect(pos.x + (Math.random()*16-8), pos.y + (Math.random()*16-8), 3, 3); } }
            else { ctx.strokeStyle = currentColor; ctx.shadowBlur = 0; } ctx.lineTo(pos.x, pos.y); ctx.stroke();
        }
        window.changeColor = function(color, mode, btn) { currentColor = color; penMode = mode; document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active')); btn.classList.add('active'); };
        window.clearCanvas = function() { if(confirm('全部消す！？')) { ctx.clearRect(0,0,canvas.width,canvas.height); hasDrawnSomething = false; } };
        function escapeHtml(s) { return s ? s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') : ""; }

        window.addEventListener('DOMContentLoaded', () => { initApp(); });
        setTimeout(initApp, 500);
    </script>
</body>
</html>`;

app.get('/', (req, res) => { res.send(htmlContent); });
app.get('/note/:id', (req, res) => { res.send(htmlContent); });

app.post('/api/notes', (req, res) => {
    let { title, membersRaw, theme } = req.body;
    if (!title || !membersRaw) return res.status(400).send('入力が足りないよ☆');
    
    membersRaw = membersRaw.replace(/，/g, ',').replace(/、/g, ',');
    const members = membersRaw.split(",").map(m => m.trim()).filter(m => m !== "");
    
    if (members.length === 0) return res.status(400).send('メンバーを入力してね☆');

    const db = readDB();
    const noteId = crypto.randomUUID();
    db.notes[noteId] = { noteId, title, members, theme: theme || '特になし☆', currentTurn: members[0], createdAt: new Date().toISOString() };
    db.pages[noteId] = [];
    writeDB(db);
    
    res.redirect('/note/' + noteId);
});

app.get('/api/notes-json/:id', (req, res) => {
    const db = readDB();
    const note = db.notes[req.params.id];
    if (!note) return res.status(404).json({ error: 'ノートがないよぅ' });
    res.json({ note, pages: db.pages[req.params.id] || [] });
});

app.post('/api/notes/:id/pages', (req, res) => {
    const noteId = req.params.id;
    const { author, message, question, drawing } = req.body;
    const db = readDB();
    const note = db.notes[noteId];
    if (!note) return res.status(404).json({ error: 'ノートがないよ' });
    let drawingUrl = '';
    if (drawing && drawing.startsWith('data:image/png;base64,')) {
        const base64Data = drawing.replace(/^data:image\/png;base64,/, "");
        const filename = `${noteId}_${Date.now()}.png`;
        fs.writeFileSync(path.join(UPLOAD_DIR, filename), base64Data, 'base64');
        drawingUrl = `/drawings/${filename}`;
    }
    db.pages[noteId].push({ author, message, question, drawingUrl, createdAt: new Date().toISOString() });
    const currentIndex = note.members.indexOf(author);
    const nextIndex = (currentIndex + 1) % note.members.length;
    note.currentTurn = note.members[nextIndex];
    writeDB(db);
    try { io.emit('update_' + noteId); } catch(e) {}
    res.json({ success: true });
});

