    <script>
        let noteId = ""; let currentNoteData = null; let myName = localStorage.getItem("girlName") || "";
        let socket = null; try { socket = io(); } catch(e) {}
        const pathMatch = window.location.pathname.match(/\\/note\\/([a-zA-Z0-9_-]+)/); if(pathMatch) noteId = pathMatch[1];
        
