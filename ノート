app.use(express.json({ limit: '10mb' }));
app.use(express.urlencoded({ extended: true, limit: '10mb' }));

// Renderの永続ディスク用パス（/data）を使用
const DB_DIR = path.join('/', 'data');
const DB_FILE = path.join(DB_DIR, 'notebook_db.json');
const UPLOAD_DIR = path.join(DB_DIR, 'drawings');

function ensureDB() {
    try {
        if (!fs.existsSync(DB_DIR)) { fs.mkdirSync(DB_DIR, { recursive: true }); }
        if (!fs.existsSync(DB_FILE)) { fs.writeFileSync(DB_FILE, JSON.stringify({ notes: {}, pages: {} }), 'utf8'); }
        if (!fs.existsSync(UPLOAD_DIR)) { fs.mkdirSync(UPLOAD_DIR, { recursive: true }); }
    } catch (e) {
        console.error("ストレージ作成エラー:", e);
    }
}

function readDB() {
    ensureDB();
    try { return JSON.parse(fs.readFileSync(DB_FILE, 'utf8')); } catch(e) { return { notes: {}, pages: {} }; }
}

function writeDB(data) {
    ensureDB();
    try { fs.writeFileSync(DB_FILE, JSON.stringify(data, null, 2), 'utf8'); } catch(e) { console.error("DB書き込みエラー:", e); }
}

